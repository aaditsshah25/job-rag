# Copy this file to .env and fill in your keys
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...
PINECONE_INDEX=job-listings1
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
OPENAI_CHAT_MODEL=gpt-4o
TOP_K=20
TOP_N_RESULTS=5
JOBMATCH_API_KEY=your-random-api-key-here
# Comma-separated list of allowed frontend origins (no trailing slashes)
# Add your Vercel domain here: https://<your-app>.vercel.app
ALLOWED_ORIGINS=https://jobmatch-ai-app.vercel.app,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
DB_PATH=./data/jobmatch.db
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@jobmatchai.dev

# External data sources (optional, disabled by default)
ENABLE_EXTERNAL_SOURCES=false

# USAJOBS API (requires both)
USAJOBS_API_KEY=
USAJOBS_API_EMAIL=

# Adzuna API (requires both)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
ADZUNA_WHAT=software engineer
ADZUNA_WHERE=united states

# Jooble API
JOOBLE_API_KEY=
JOOBLE_KEYWORDS=software engineer
JOOBLE_LOCATION=United States
JOOBLE_PAGE=1

# Greenhouse public boards (comma-separated board tokens)
# Example: GREENHOUSE_BOARD_TOKENS=airtable,stripe
GREENHOUSE_BOARD_TOKENS=

# Lever postings (comma-separated site names)
# Example: LEVER_SITE_NAMES=netflix,coinbase
LEVER_SITE_NAMES=
