# Copy this file to .env and fill in your keys

OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...

# Pinecone index settings (defaults match the existing n8n workflow)
PINECONE_INDEX=job-listings1
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Model settings
OPENAI_CHAT_MODEL=gpt-4o

# RAG settings
TOP_K=20          # candidates retrieved from Pinecone
TOP_N_RESULTS=5   # jobs shown to the user

# Path to CSV (auto-resolved relative to backend.py if not set)
# CSV_PATH=/absolute/path/to/GENAI_RAG_Dataset - Sheet1.csv
